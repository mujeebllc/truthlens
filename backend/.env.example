# TruthLens Environment Variables Template

# Optional: Google Fact Check Tools API Key
# Go to Google Cloud Console, enable 'Fact Check Tools API', create an API key (free tier, no billing required).
# If left empty, TruthLens automatically falls back to the seeded local mock dataset.
GOOGLE_FACTCHECK_API_KEY=

# Optional: Anthropic Claude API Key for richer contextual justifications.
# If left empty, TruthLens uses local template-based explanations.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
